{
  "name": "vibegov",
  "version": "1.0",
  "source": "https://governance-foundation.github.io/vibegov.io",
  "folders": [
    ".governance/rules",
    ".governance/project",
    ".governance/specs",
    "openspec/specs"
  ],
  "rules_policy": {
    "scope": "governance_only",
    "path_glob": ".governance/rules/*.mdc",
    "forbid_feature_spec_content": true
  },
  "spec_policy": {
    "scope": "feature_and_change_spec_only",
    "path_glob": ".governance/specs/*",
    "is_single_source_of_truth_for_features": true
  },
  "openspec_policy": {
    "translate_raw_requests_before_code": true,
    "specs_path_glob": "openspec/specs/*",
    "traceability_entrypoint": "openspec/traceability.md",
    "changes_path_glob": "openspec/changes/*",
    "migration_path_glob": "openspec/migration/*",
    "requirements_must_define_acceptance_and_verification": true
  },
  "compatibility": {
    "mirror_to_provider_rules_if_present": true,
    "mirror_source_glob": ".governance/rules/*.mdc",
    "mirror_target_strategy": "detect_existing_provider_native_rules_directories",
    "use_placeholders": false,
    "if_no_provider_directory_exists": "use_.governance/rules_only",
    "report_detected_mirror_targets": true,
    "preserve_intent": true
  },
  "delivery_loop": [
    "Observe",
    "Plan",
    "Implement",
    "Verify",
    "Document"
  ],
  "active_rules": [
    "gov-01-instructions",
    "gov-02-workflow",
    "gov-03-communication",
    "gov-04-quality",
    "gov-05-testing",
    "gov-06-issues",
    "gov-07-tasks",
    "gov-08-exploratory-review"
  ],
  "hard_gate_before_product_code": true,
  "pre_coding_required_outputs": [
    ".governance/project/PROJECT_INTENT.md",
    ".governance/specs/SPEC-001-<feature>.md",
    "openspec/specs/...",
    "openspec/traceability.md",
    "backlog_mapped_to_spec_sections",
    "repo_sdlc_foundation_proportionate_to_context"
  ],
  "stop_after_pre_coding_outputs": true,
  "task_completion_requirements": [
    "verification_evidence",
    "traceability_update"
  ],
  "bootstrap_foundation_expectations": {
    "goal": "enterprise_ready_sdlc_foundation",
    "include": [
      "structured_requirements_before_code",
      "explicit_acceptance_criteria",
      "verification_and_test_intent",
      "traceability_entrypoint",
      "backlog_or_task_mapping",
      "onboarding_or_readme_entrypoint",
      "delivery_workflow_guidance"
    ],
    "host_specific_when_appropriate": [
      "issue_templates",
      "ci_workflows",
      "pr_templates",
      "codeowners"
    ],
    "external_mutations_not_implied": [
      "push_to_remote",
      "cloud_provisioning",
      "org_level_repo_setting_changes"
    ]
  }
}


